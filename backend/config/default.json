    "pass": null,
    "transactions": false
  },
  "registry": {
    "connection": {
      "internal": "https://registry:5000",
      "insecure": true
    },
    "service": "RegistryAuth",
    "issuer": "RegistryIssuer",
    "insecure": true
  },
  "federation": {
    "id": "localBailo",
    "state": "enabled",
