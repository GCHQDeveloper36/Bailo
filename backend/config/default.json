    "protocol": "http",
    "host": "localhost",
    "port": 8080,
    "privateKey": "/certs/key.pem",
    "publicKey": "/certs/cert.pem",
    "jwks": "./certs/jwks.json"
  },
  "httpClient": {
    "defaultOpts": {
      "rejectUnauthorized": false
    },
    "proxy": "",
    "noProxy": ["localhost", "127.0.0.1", "registry", "minio"]
